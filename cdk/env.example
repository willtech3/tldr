# AWS deployment region
CDK_DEFAULT_REGION=us-west-2
AWS_ACCOUNT_ID=123456789012

# Slack Bot Credentials
# Store these as SSM SecureString parameters and pass only parameter names to CDK.
# Example:
# aws ssm put-parameter --name /tldr/slack/bot-token --type SecureString --value xoxb-...
# aws ssm put-parameter --name /tldr/slack/signing-secret --type SecureString --value ...
SLACK_BOT_TOKEN_PARAMETER_NAME=/tldr/slack/bot-token
SLACK_SIGNING_SECRET_PARAMETER_NAME=/tldr/slack/signing-secret

# Optional: For testing locally
SLACK_APP_ID=your-app-id-here

# OpenAI API Key and Organization ID
# Store the API key as an SSM SecureString parameter.
OPENAI_API_KEY_PARAMETER_NAME=/tldr/openai/api-key
# Optional: Store the organization ID in SSM too if you use one.
OPENAI_ORG_ID_PARAMETER_NAME=/tldr/openai/org-id
# Optional: Override the OpenAI model used by the Rust worker
OPENAI_MODEL=gpt-5.2

# Streaming summaries to Slack assistant threads (worker Lambda)
# When enabled, the Rust worker uses Slack's chat.*Stream APIs to progressively
# stream the summary text into the assistant thread instead of posting once.
ENABLE_STREAMING=false

# Optional tuning for Slack streaming safety.
# Must be <= 12000 (Slack's per-call markdown_text limit).
STREAM_MAX_CHUNK_CHARS=4000

# Minimum time between chat.appendStream calls (ms). Default is 1000.
STREAM_MIN_APPEND_INTERVAL_MS=1000
